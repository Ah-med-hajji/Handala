# ── Mock mode ────────────────────────────────────────────────────────────────
# Set to true to run fully locally with zero external dependencies.
# Admin login: any email + password "admin123"
# Images served from picsum.photos — no uploads needed.
NEXT_PUBLIC_USE_MOCK_DATA=true

# ── Supabase (required when NEXT_PUBLIC_USE_MOCK_DATA=false) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
